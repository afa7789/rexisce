# Maintainer: rexisce contributors
pkgname=rexisce
pkgver=0.1.0
pkgrel=1
pkgdesc="Native XMPP desktop messenger built with Rust and iced"
arch=('x86_64')
url="https://github.com/owner/rexisce"
license=('MIT')
depends=('dbus' 'openssl')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --bin rexisce
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/rexisce" "$pkgdir/usr/bin/rexisce"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
